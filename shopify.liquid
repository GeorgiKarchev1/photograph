    <!-- 3 Опаковки -->
    <button type="button" class="bundle-card" data-qty="3" aria-pressed="false">
      <div class="bundle-image">
        <div class="free-shipping-badge">⚡ БЕЗПЛАТНА ДОСТАВКА</div>
        <img
          src="https://cdn.shopify.com/s/files/1/1012/2802/0051/files/viber_image_2026-02-17_17-45-17-894.png?v=1772489539"
